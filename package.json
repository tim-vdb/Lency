{
  "name": "crazy_dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:eslint": "npx @next/codemod@canary next-lint-to-eslint-cli .",
    "db:deploy": "npx prisma migrate deploy",
    "reset": "doppler run -- npx prisma migrate reset",
    "validate": "doppler run -- npx prisma validate",
    "migrate": "doppler run -- npx prisma migrate dev",
    "migrate:prod": "doppler run -- prisma migrate deploy",
    "generate": "doppler run -- prisma generate",
    "push": "doppler run -- prisma db push",
    "studio": "doppler run -- prisma studio",
    "all": "doppler run -- npx prisma migrate dev  && concurrently \"doppler run -- npm run dev\" \"doppler run -- npm run studio\"",
    "all:env": "npx prisma migrate dev  && concurrently \"npm run dev\" \"npm run studio\"",
    "all:local": "npx prisma generate  && npx prisma db push  && concurrently \"npm run dev\" \"npm run studio\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
