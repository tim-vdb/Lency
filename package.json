{
  "name": "crazy_dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:eslint": "npx @next/codemod@canary next-lint-to-eslint-cli .",
    "db:deploy": "npx prisma migrate deploy --schema=src/prisma/schema.prisma",
    "migrate": "npx prisma migrate dev --schema=src/prisma/schema.prisma",
    "migrate:prod": "doppler run -- prisma migrate deploy --schema=src/prisma/schema.prisma",
    "generate": "doppler run -- prisma generate --schema=src/prisma/schema.prisma",
    "push": "doppler run -- prisma db push --schema=src/prisma/schema.prisma",
    "studio": "doppler run -- prisma studio --schema=src/prisma/schema.prisma",
    "all": "concurrently \"doppler run -- npx prisma db push --schema=src/prisma/schema.prisma\" \"doppler run -- npm run dev\" \"doppler run -- npm run studio\"",
    "all:local": "concurrently \"npx prisma db push --schema=src/prisma/schema.prisma\" \"npm run dev\" \"npm run studio\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.18.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@uploadthing/react": "^7.3.3",
    "better-auth": "^1.3.31",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "eslint-plugin-boundaries": "^5.1.0",
    "lucide-react": "^0.548.0",
    "next": "16.0.0",
    "next-safe-action": "^8.0.11",
    "next-themes": "^0.4.6",
    "next-zod-route": "^1.0.0",
    "react": "19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.65.0",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "uploadthing": "^7.7.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^20",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.1.0",
    "eslint-plugin-import": "^2.32.0",
    "prisma": "^6.18.0",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
