{
  "name": "lency",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "vercel-build": "npx prisma generate --schema=src/back/prisma/ && next build && npx prisma migrate deploy",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:eslint": "npx @next/codemod@canary next-lint-to-eslint-cli .",
    "db:deploy": "npx prisma migrate deploy",
    "reset": "doppler run -- npx prisma migrate reset",
    "seed": "doppler run -- npx prisma db seed",
    "validate": "doppler run -- npx prisma validate",
    "migrate": "doppler run -- npx prisma migrate dev",
    "migrate:fix": "doppler run -- npx prisma db pull && doppler run -- npx prisma migrate dev",
    "migrate:prod": "doppler run -- prisma migrate deploy",
    "generate": "doppler run -- prisma generate",
    "pull": "doppler run -- npx prisma db pull",
    "push": "doppler run -- prisma db push",
    "migrate:status": "doppler run -- npx prisma migrate status",
    "studio": "doppler run -- prisma studio -p 5555 --browser none",
    "all": "doppler run -- concurrently \"npm run dev\" \"npm run studio\"",
    "all:env": "npx prisma migrate dev && concurrently \"npm run dev\" \"npm run studio\"",
    "all:local": "npx prisma generate && npx prisma db push && concurrently \"npm run dev\" \"npm run studio\"",
    "email": "email dev --dir ./src/front/emails --port 4000"
  },
