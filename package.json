{
  "name": "crazy_dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:eslint": "npx @next/codemod@canary next-lint-to-eslint-cli .",
    "db:deploy": "npx prisma migrate deploy --schema=src/prisma/schema.prisma",
    "migrate": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "generate": "prisma generate --schema=src/prisma/schema.prisma",
    "studio": "prisma studio --schema=src/prisma/schema.prisma",
    "all": "concurrently \"doppler run -- npx prisma migrate deploy --schema=src/prisma/schema.prisma\" \"doppler run -- npm run dev\" \"doppler run -- npm run studio\"",
    "all:local": "concurrently \"npx prisma migrate deploy --schema=src/prisma/schema.prisma\" \"npm run dev\" \"npm run studio\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
