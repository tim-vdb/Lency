    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "eslint-plugin-boundaries": "^5.0.2",
    "lucide-react": "^0.544.0",
    "next": "15.5.3",
    "next-safe-action": "^8.0.11",
    "next-themes": "^0.4.6",
    "next-zod-route": "^1.0.0",
    "react": "19.1.0",
    "react-day-picker": "^9.11.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.63.0",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
