model AdminEmail {
  id          String         @id @default(cuid())
  messageId   String?        @unique
  type        AdminEmailType
  box         AdminEmailBox
  fromEmail   String
  fromName    String?
  toEmail     String
  subject     String
  htmlContent String?        @db.Text
  textContent String?        @db.Text
  isRead      Boolean        @default(false)
  isStarred   Boolean        @default(false)
  parentId    String?
  parent      AdminEmail?    @relation("EmailReplies", fields: [parentId], references: [id])
  replies     AdminEmail[]   @relation("EmailReplies")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("admin_emails")
}
