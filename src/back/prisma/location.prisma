/// *
/// LOCALISATION - LIEUX & SPOTS
model MapLocation {
    id          String    @id @default(cuid())
    name        String
    latitude    Float
    longitude   Float
    description String?
    Spots       Spot[]
    Projects    Project[]

    createdAt DateTime @default(now())
}

model Spot {
    id            String       @id @default(cuid())
    name          String
    description   String
    address       String
    city          String
    author        String
    rating        Int          @default(0)
    rating_count  Int          @default(0)
    mapLocation   MapLocation? @relation(fields: [mapLocationId], references: [id])
    mapLocationId String?
}
