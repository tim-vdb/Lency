model Blog {
  id        String     @id @default(cuid())
  title     String
  content   String
  coverUrl  String?
  tags      String[]
  status    BlogStatus @default(DRAFT)
  authorId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
}