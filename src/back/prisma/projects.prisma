/// *
/// PROJETS & ÉVÉNEMENTS
model Project {
  id            String        @id @default(cuid())
  title         String
  description   String
  status        ProjectStatus @default(PUBLISHED)
  visibility    Visibility    @default(PUBLIC)
  ownerId       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  mapLocationId String?
  // Marketplace fields
  bannerUrl         String?
  projectType       String?
  remunerationType  RemunerationType?
  level             ProjectLevel?
  workMode          WorkMode?
  startDate         DateTime?
  roles             Json?
  attachments   Json?
  commentCount  Int           @default(0)
  mapLocation   MapLocation?  @relation(fields: [mapLocationId], references: [id])
  owner         User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  participants  User[]        @relation("Participants")
  comments      Comment[]
}

model Event {
  id           String    @id @default(cuid())
  title        String
  description  String
  location     String?
  participants Int       @default(1)
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime  @default(now())
  userId       String?
  typeEvent    TypeEvent
  users        User[]    @relation("UserEvent")
}
