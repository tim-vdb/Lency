generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma_client"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
}

/// *
/// AUTHENTIFICATION & SESSIONS
model User {
  id                        String                 @id @default(cuid())
  firstname                 String?
  lastname                  String?
  email                     String                 @unique
  password                  String?
  username                  String?                @unique
  phone                     String?
  bio                       String?
  role                      Role                   @default(MEMBER)
  isPremium                 Boolean                @default(false)
  isMarketplaceTalent       Boolean                @default(false)
  cv                        String?
  portfolio                 String?
  eventId                   String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  emailVerified             Boolean                @default(false)
  image                     String?
  avatarUrl                 String?
  name                      String?
  pendingEmail              String?
  emailChangeToken          String?
  emailChangeTokenExpiresAt DateTime?
  articles                  Article[]
  creator                   Category[]             @relation("CreatedCategories")
  Categorys                 Category[]
  Comments                  Comment[]
  NewsletterSubscribers     NewsletterSubscriber[]
  Posts                     Post[]
  projects                  Project[]
  spots                     Spot[]
  subscription              Subscription?
  configs                   UserConfig[]
  accounts                  Account[]
  sessions                  Session[]
  participants              Project[]              @relation("Participants")
  badges                    Badge[]                @relation("UserBadge")
  events                    Event[]                @relation("UserEvent")
  savedPosts                PostSave[]
  postVotes                 PostVote[]
  reportedPosts             PostReport[]
  reportedProjects          ProjectReport[]
  categoryFollows           CategoryFollow[]
  resources                 Resource[]             @relation("UserResources")
  resourceVotes             ResourceVote[]
  resourceSaves             ResourceSave[]
  followers                 UserFollow[]           @relation("Following")
  following                 UserFollow[]           @relation("Followers")
  reportsMade               UserReport[]           @relation("UserReporters")
  reportsReceived           UserReport[]           @relation("ReportedUsers")
  socialLinks               UserSocialLink[]
  feedbacks                 Feedback[]
}

model UserSocialLink {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  url       String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("user_social_links")
}

/// *
/// SESSIONS & ACCOUNTS
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prenom  String
  nom     String
  email   String
  sujet   String
  message String @db.Text

  type   ContactType   @default(CONTACT_GENERAL)
  status ContactStatus @default(EN_ATTENTE)

  @@map("contact_messages")
}

model Feedback {
  id          String   @id @default(cuid())
  description String   @db.Text
  imageUrl    String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("feedbacks")
}
