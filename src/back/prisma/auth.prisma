/// *
/// AUTHENTIFICATION & SESSIONS
model User {
    id        String  @id @default(cuid())
    firstname String
    lastname  String
    email     String  @unique
    password  String
    username  String  @unique
    phone     String?
    bio       String?
    avatarUrl String?
    role      Role    @default(MEMBER)
    isPremium Boolean @default(false)
    cv        String?
    portfolio String?

    projects              Project[]
    participants          Project[]              @relation("Participants")
    articles              Article[]
    configs               UserConfig[]
    badges                Badge[]                @relation("UserBadge")
    accounts              Account[]
    sessions              Session[]
    subscription          Subscription?
    NewsletterSubscribers NewsletterSubscriber[]
    Posts                 Post[]
    Comments              Comment[]
    Categorys             Category[]
    creator               Category[]             @relation("CreatedCategories")
    eventId               String
    events                Event[]                @relation("UserEvent")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

/// *
/// SESSIONS & ACCOUNTS
model Session {
    id        String   @id @default(cuid())
    expiresAt DateTime
    token     String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    ipAddress String?
    userAgent String?
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("session")
}

model Account {
    id                    String    @id @default(cuid())
    accountId             String
    providerId            String
    userId                String
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @default(now()) @updatedAt
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("account")
}

model Verification {
    id         String   @id @default(cuid())
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @default(now()) @updatedAt

    @@map("verification")
}
