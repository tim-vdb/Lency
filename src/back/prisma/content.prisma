/// *
/// CONTENU - ARTICLES, POSTS & COMMENTS
model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  published Boolean  @default(false)
  image     String?
  views     Int      @default(0)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Category {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  description     String?
  visibility      Visibility       @default(PUBLIC)
  createdBy       String
  iconUrl         String?
  bannerUrl       String?
  rules           String?
  isNSFW          Boolean          @default(false)
  members         Int              @default(0)
  postCount       Int              @default(0)
  subscriberCount Int              @default(0)
  lastPostAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userId          String?
  creator         User             @relation("CreatedCategories", fields: [createdBy], references: [id])
  user            User?            @relation(fields: [userId], references: [id])
  posts           Post[]
  ressources      Resource[]
  followers       CategoryFollow[]

  @@index([slug])
  @@index([visibility])
  @@index([createdBy])
}

model Post {
  id           String       @id @default(cuid())
  title        String
  content      String
  isLocked     Boolean      @default(false)
  categoryId   String
  authorId     String
  format       PostFormat   @default(DESKTOP)
  viewCount    Int          @default(0)
  upvoteCount  Int          @default(0)
  commentCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  isPublished  Boolean      @default(false)
  saveCount    Int          @default(0)
  comments     Comment[]
  saves        PostSave[]
  votes        PostVote[]
  hides        PostHide[]
  reports      PostReport[]
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

model Comment {
  id            String    @id @default(cuid())
  content       String
  imageUrl      String?
  videoUrl      String?
  postId        String?
  resourceId    String?
  authorId      String
  parentId      String?
  upvoteCount   Int       @default(0)
  downvoteCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  children      Comment[] @relation("CommentReplies")
  post          Post?     @relation(fields: [postId], references: [id])
  resource      Resource? @relation(fields: [resourceId], references: [id])

  @@index([postId])
  @@index([resourceId])
  @@index([authorId])
  @@index([parentId])
}

model PostSave {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model PostVote {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model PostHide {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model PostReport {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model CategoryFollow {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
}
