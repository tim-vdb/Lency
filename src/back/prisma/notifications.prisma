/// *
/// ABONNEMENTS NOTIFICATIONS CATÉGORIE
model CategoryNotificationSubscription {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([categoryId])
}

/// *
/// NOTIFICATIONS
model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "new_application" | "application_status"
  title       String
  description String
  data        Json     // payload flexible : applicationId, projectId, status, etc.
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}
