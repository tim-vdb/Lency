{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit *)",
      "Bash(npx tsc --noEmit)",
      "Bash(curl -s *)",
      "Bash(curl -sI *)",
      "Bash(gh search *)",
      "Bash(npm view *)",
      "Bash(npm search *)",
      "Bash(ipconfig)",
      "Bash(ipconfig *)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(del:*)",
      "Bash(rmdir:*)",
      "Bash(git branch -d:*)",
      "Bash(git branch -D:*)",
      "Bash(git push origin --delete:*)",
      "Bash(DROP TABLE:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(TRUNCATE:*)",
      "Bash(DELETE FROM:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(prisma migrate reset:*)"
    ]
  }
}
