{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit(*.tsx)",
      "Bash(npx tsc --noEmit *)",
      "Bash(npx tsc --noEmit)",
      "Bash(curl -s *)",
      "Bash(curl -sI *)",
      "Bash(gh search *)",
      "Bash(npm view *)",
      "Bash(npm search *)",
      "Bash(ipconfig)",
      "Bash(ipconfig *)",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__plugin_figma_figma__get_screenshot",
      "mcp__plugin_figma_figma__get_metadata",
      "mcp__plugin_figma_figma__get_variable_defs",
      "mcp__plugin_figma_figma__get_libraries",
      "mcp__plugin_figma_figma__search_design_system",
      "mcp__plugin_figma_figma__use_figma",
      "mcp__plugin_figma_figma__whoami",
      "mcp__plugin_figma_figma__get_code_connect_map",
      "mcp__plugin_figma_figma__get_figjam",
      "mcp__plugin_figma_figma__generate_figma_design",
      "mcp__plugin_figma_figma__upload_assets",
      "Bash(doppler run *)",
      "Bash(doppler secrets *)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(del:*)",
      "Bash(rmdir:*)",
      "Bash(git branch -d:*)",
      "Bash(git branch -D:*)",
      "Bash(git push origin --delete:*)",
      "Bash(DROP TABLE:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(TRUNCATE:*)",
      "Bash(DELETE FROM:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(prisma migrate reset:*)"
    ]
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true
  }
}